<Window x:Class="SoundCalcs.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SoundCalcs.UI.Converters"
        xmlns:domain="clr-namespace:SoundCalcs.Domain"
        xmlns:ui="clr-namespace:SoundCalcs.UI"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="SoundCalcs"
        Height="680" Width="920"
        MinHeight="500" MinWidth="700"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#FF1F1F1F" />
                    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#FF292929" />
                    <SolidColorBrush x:Key="BorderBrush" Color="#FF444444" />
                    <SolidColorBrush x:Key="ForegroundBrush" Color="#EEEEEE" />
                    <SolidColorBrush x:Key="HighlightBrush" Color="#FF505050" />
                    <SolidColorBrush x:Key="IconForegroundBrush" Color="#FF808080" />
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/SoundCalcs;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <local:InverseBoolConverter x:Key="InverseBool"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisStd"/>

            <!-- Label style -->
            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource IconForegroundBrush}"/>
                <Setter Property="Margin" Value="0,4,8,4"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style x:Key="ValueLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Input text box (uses theme brushes) -->
            <Style x:Key="InputBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="CaretBrush" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="False"
                                              VerticalAlignment="Center"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF0078D7"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource IconForegroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Section header -->
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="Margin" Value="0,8,0,6"/>
            </Style>

            <Style x:Key="Separator" TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Margin" Value="0,6"/>
            </Style>

            <!-- ComboBox (inline dark) -->
            <Style x:Key="ComboStyle" TargetType="ComboBox">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="22"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          Margin="8,0,2,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          IsHitTestVisible="False"/>
                                        <Path Grid.Column="1"
                                              Data="M 0,0 L 4,4 L 8,0"
                                              Stroke="{DynamicResource IconForegroundBrush}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round"
                                              Width="8" Height="4"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                                <ToggleButton OverridesDefaultStyle="True"
                                              Background="Transparent" BorderThickness="0"
                                              IsChecked="{Binding Path=IsDropDownOpen,
                                                                  RelativeSource={RelativeSource TemplatedParent},
                                                                  Mode=TwoWay}"
                                              Focusable="False" Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" CornerRadius="4"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       Placement="Bottom"
                                       PopupAnimation="Slide">
                                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                                            MaxHeight="200"
                                            Margin="0,2,0,0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{DynamicResource IconForegroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF0078D7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border x:Name="Bg"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#FF555555"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Action button (Pulse style) -->
            <Style x:Key="BtnStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Margin" Value="0,0,4,0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#FF555555"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary button (blue) -->
            <Style x:Key="SuccessBtnStyle" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
                <Setter Property="Background" Value="#FF0078D7"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#FF0078D7"/>
            </Style>

            <!-- Danger / negative button -->
            <Style x:Key="DangerBtnStyle" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
                <Setter Property="Foreground" Value="#FFDC6B6B"/>
                <Setter Property="BorderBrush" Value="#66DC6B6B"/>
            </Style>

            <!-- Accent / draft button (amber) -->
            <Style x:Key="AccentBtnStyle" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
                <Setter Property="Background" Value="#FFCA8A04"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#FFCA8A04"/>
            </Style>

            <!-- DataGrid column header -->
            <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource IconForegroundBrush}"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </Style>

            <!-- Tab Item style -->
            <Style TargetType="TabItem">
                <Setter Property="Foreground" Value="{DynamicResource IconForegroundBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}"
                                    Cursor="Hand">
                                <ContentPresenter x:Name="Content"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF0078D7"/>
                                    <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TabControl style -->
            <Style TargetType="TabControl">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- Checkbox -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer transparent grid for blur + resize grips -->
    <Grid>
        <!-- Shadow border -->
        <Border Margin="10" CornerRadius="10">
            <Border.Effect>
                <BlurEffect Radius="10"/>
            </Border.Effect>
            <Border.Background>
                <SolidColorBrush Color="Black" Opacity="0.6"/>
            </Border.Background>
        </Border>

        <!-- Main content border -->
        <Border Margin="10"
                Background="{DynamicResource PrimaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Border.Clip>
                <RectangleGeometry RadiusX="10" RadiusY="10">
                    <RectangleGeometry.Rect>
                        <MultiBinding Converter="{x:Static local:SizeToRectConverter.Instance}">
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Border}"/>
                        </MultiBinding>
                    </RectangleGeometry.Rect>
                </RectangleGeometry>
            </Border.Clip>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="24"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <ui:TitleBar Grid.Row="0"/>

                <!-- Tab Control -->
                <TabControl Grid.Row="1" Margin="4,0,4,0"
                            Background="Transparent"
                            BorderThickness="0">

            <!-- ============ MODEL TAB ============ -->
            <TabItem Header="Model">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Linked Model"/>
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Select the architectural model to analyse geometry from:"/>

                        <Button Content="Refresh Links" Style="{StaticResource BtnStyle}"
                                Click="RefreshLinks_Click" HorizontalAlignment="Left" Margin="0,4"/>

                        <ListBox x:Name="LinksListBox"
                                 ItemsSource="{Binding AvailableLinks}"
                                 SelectedItem="{Binding SelectedLink}"
                                 Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Height="120" Margin="0,4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding LinkName}" Margin="4,2"/>
                                        <TextBlock Text="{Binding FilePath}" Foreground="{DynamicResource IconForegroundBrush}" Margin="8,2,0,2" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <WrapPanel Orientation="Horizontal" Margin="0,4">
                            <Button Content="Select Boundary" Style="{StaticResource BtnStyle}"
                                    Click="SelectBoundary_Click"/>
                            <Button Content="Auto-Detect Walls" Style="{StaticResource BtnStyle}"
                                    Margin="8,0,0,0"
                                    Click="AutoDetectWalls_Click"
                                    ToolTip="Reads Revit wall elements from the host and linked model and estimates STC ratings automatically"/>
                        </WrapPanel>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Selected Walls"
                                   Margin="0,8,0,4"/>

                        <DataGrid ItemsSource="{Binding WallLineGroups}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  Background="{DynamicResource SecondaryBackgroundBrush}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                  RowBackground="{DynamicResource SecondaryBackgroundBrush}"
                                  AlternatingRowBackground="{DynamicResource PrimaryBackgroundBrush}"
                                  HeadersVisibility="Column"
                                  Height="120" Margin="0,4"
                                  SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeaderStyle}"/>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Line Style" Binding="{Binding LineStyleName}" Width="160" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Segments" Binding="{Binding SegmentCount}" Width="70" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Length" Binding="{Binding TotalLength}" Width="70" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Wall Type" Width="280">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Style="{StaticResource ComboStyle}"
                                                      ItemsSource="{Binding AvailableWallTypes}"
                                                      SelectedItem="{Binding WallType, UpdateSourceTrigger=PropertyChanged}"
                                                      DisplayMemberPath="DisplayName"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Style="{StaticResource Separator}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Speaker Category"/>
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Revit category to scan for speakers:"/>
                        <ComboBox Style="{StaticResource ComboStyle}" Width="280" HorizontalAlignment="Left"
                                  x:Name="CategoryCombo" SelectedItem="{Binding SpeakerCategoryName}">
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">OST_DataDevices</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">OST_MechanicalEquipment</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">OST_ElectricalFixtures</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">OST_ElectricalEquipment</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">OST_CommunicationDevices</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">OST_GenericModel</sys:String>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ SPEAKERS TAB ============ -->
            <TabItem Header="Speakers">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Pick Speakers" Style="{StaticResource BtnStyle}" Click="PickSpeaker_Click"/>
                        <Button Content="Clear Picked" Style="{StaticResource DangerBtnStyle}" Click="ClearPickedSpeakers_Click"/>
                        <Button Content="Save Mappings" Style="{StaticResource SuccessBtnStyle}" Click="SaveSettings_Click"/>
                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding PickedSpeakerSummary}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SpeakerGroups}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              Background="{DynamicResource SecondaryBackgroundBrush}"
                              Foreground="{DynamicResource ForegroundBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                              RowBackground="{DynamicResource SecondaryBackgroundBrush}"
                              AlternatingRowBackground="{DynamicResource PrimaryBackgroundBrush}"
                              HeadersVisibility="Column"
                              SelectionMode="Single">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Family" Binding="{Binding FamilyName}" Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="130" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Level" Binding="{Binding LevelName}" Width="90" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Profile" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Style="{StaticResource ComboStyle}"
                                                  SelectedItem="{Binding ProfileSource, UpdateSourceTrigger=PropertyChanged}">
                                            <domain:ProfileSourceType>SimpleOmni</domain:ProfileSourceType>
                                            <domain:ProfileSourceType>SimpleConical</domain:ProfileSourceType>
                                            <domain:ProfileSourceType>WallMounted</domain:ProfileSourceType>
                                            <domain:ProfileSourceType>GllFile</domain:ProfileSourceType>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="SPL (dB)" Binding="{Binding OnAxisSplDb}" Width="70"/>
                            <DataGridTextColumn Header="Cone Angle" Binding="{Binding ConeHalfAngleDeg}" Width="80"/>
                            <DataGridTextColumn Header="Direction (°)" Binding="{Binding OutputDirectionDeg}" Width="85"/>
                            <DataGridTextColumn Header="Tilt (°)" Binding="{Binding WallMountTiltDeg}" Width="65"/>
                            <DataGridTextColumn Header="GLL Path" Binding="{Binding GllFilePath}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ============ GRID TAB ============ -->
            <TabItem Header="Grid">
                <StackPanel Margin="12">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Receiver Grid Settings"/>

                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Grid Spacing (m):"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource InputBoxStyle}"
                                 Text="{Binding GridSpacing, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}"
                                   Text="Distance between receiver points" FontSize="11"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Receiver Height (m):"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputBoxStyle}"
                                 Text="{Binding ReceiverHeight, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}"
                                   Text="Height above floor (1.2m seated, 1.5m standing)" FontSize="11"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Boundary Offset (m):"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource InputBoxStyle}"
                                 Text="{Binding BoundaryOffset, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource LabelStyle}"
                                   Text="Inset from room walls" FontSize="11"/>

                        <CheckBox Grid.Row="3" Grid.Column="0" Content="Min SPL Threshold"
                                  IsChecked="{Binding UseMinSplThreshold, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource InputBoxStyle}"
                                 Text="{Binding MinSplThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding UseMinSplThreshold}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource LabelStyle}"
                                   Text="Hide areas below this dB level" FontSize="11" Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                   Style="{StaticResource SectionHeader}" Text="Octave Band Settings (125 – 8k Hz)"
                                   FontSize="12" Margin="0,10,0,4"/>

                        <!-- RT60 per band -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="RT60 (s):" Margin="0,4,0,0"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding RT60_125, UpdateSourceTrigger=PropertyChanged}" ToolTip="125 Hz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding RT60_250, UpdateSourceTrigger=PropertyChanged}" ToolTip="250 Hz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding RT60_500, UpdateSourceTrigger=PropertyChanged}" ToolTip="500 Hz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding RT60_1k, UpdateSourceTrigger=PropertyChanged}" ToolTip="1 kHz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding RT60_2k, UpdateSourceTrigger=PropertyChanged}" ToolTip="2 kHz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding RT60_4k, UpdateSourceTrigger=PropertyChanged}" ToolTip="4 kHz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding RT60_8k, UpdateSourceTrigger=PropertyChanged}" ToolTip="8 kHz"/>
                        </StackPanel>

                        <!-- Background noise per band -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Noise (dB):" Margin="0,4,0,0"/>
                        <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding Noise_125, UpdateSourceTrigger=PropertyChanged}" ToolTip="125 Hz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding Noise_250, UpdateSourceTrigger=PropertyChanged}" ToolTip="250 Hz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding Noise_500, UpdateSourceTrigger=PropertyChanged}" ToolTip="500 Hz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding Noise_1k, UpdateSourceTrigger=PropertyChanged}" ToolTip="1 kHz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding Noise_2k, UpdateSourceTrigger=PropertyChanged}" ToolTip="2 kHz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding Noise_4k, UpdateSourceTrigger=PropertyChanged}" ToolTip="4 kHz" Margin="0,0,3,0"/>
                            <TextBox Width="45" Style="{StaticResource InputBoxStyle}" Text="{Binding Noise_8k, UpdateSourceTrigger=PropertyChanged}" ToolTip="8 kHz"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Save Settings" Style="{StaticResource SuccessBtnStyle}"
                            Click="SaveSettings_Click" HorizontalAlignment="Left" Margin="0,12"/>
                </StackPanel>
            </TabItem>

            <!-- ============ RUN TAB ============ -->
            <TabItem Header="Run">
                <StackPanel Margin="12">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Computation"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <Button Content="Quick Draft" Style="{StaticResource AccentBtnStyle}"
                                Click="StartDraft_Click"
                                IsEnabled="{Binding CanRun}"
                                ToolTip="Fast preview — skips second-order and ceiling/floor reflections"/>
                        <Button Content="Full Analysis" Style="{StaticResource SuccessBtnStyle}"
                                Click="StartFull_Click"
                                IsEnabled="{Binding CanRun}"
                                Margin="8,0,0,0"/>
                        <Button Content="Cancel" Style="{StaticResource DangerBtnStyle}"
                                Click="CancelJob_Click"
                                IsEnabled="{Binding IsRunning}"
                                Margin="8,0,0,0"/>
                    </StackPanel>

                    <Border Style="{StaticResource Separator}"/>

                    <!-- Progress -->
                    <TextBlock Text="Progress:" Style="{StaticResource LabelStyle}" Margin="0,8,0,4"/>
                    <Grid>
                        <ProgressBar Height="24"
                                     Value="{Binding Progress, Mode=OneWay}"
                                     Minimum="0" Maximum="1"
                                     Background="{DynamicResource SecondaryBackgroundBrush}"
                                     Foreground="#FF0078D7"
                                     BorderBrush="{DynamicResource BorderBrush}"/>
                        <TextBlock Text="{Binding ProgressPercent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Border Style="{StaticResource Separator}"/>

                    <!-- Last run summary -->
                    <TextBlock Text="Last Run:" Style="{StaticResource LabelStyle}" Margin="0,8,0,4"/>
                    <TextBlock Text="{Binding LastRunSummary}"
                               Style="{StaticResource ValueLabelStyle}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <!-- ============ RESULTS TAB ============ -->
            <TabItem Header="Results">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Visualization"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Mode:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Style="{StaticResource ComboStyle}"
                                  ItemsSource="{Binding AvailableVisualizationModes}"
                                  SelectedItem="{Binding SelectedVisualizationMode}"
                                  Width="140" Margin="0,0,12,0"/>
                        <Button Content="Visualize Heatmap" Style="{StaticResource SuccessBtnStyle}"
                                Click="Visualize_Click"
                                IsEnabled="{Binding HasResults}"/>
                        <Button Content="Clear Visualization" Style="{StaticResource DangerBtnStyle}"
                                Click="ClearVisualization_Click"/>
                        <Button Content="Import Latest Results" Style="{StaticResource BtnStyle}"
                                Click="ImportResults_Click"/>
                    </StackPanel>

                    <Border Style="{StaticResource Separator}"/>

                    <TextBlock Text="Results Summary:" Style="{StaticResource LabelStyle}" Margin="0,8,0,4"/>
                    <TextBlock Text="{Binding LastRunSummary}"
                               Style="{StaticResource ValueLabelStyle}"
                               TextWrapping="Wrap"/>

                    <StackPanel Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}" Margin="0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Receiver Count:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueLabelStyle}"
                                       Text="{Binding LastOutput.ReceiverCount}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Min SPL (dB):"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueLabelStyle}"
                                       Text="{Binding LastOutput.MinSplDb, StringFormat={}{0:F1}}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Max SPL (dB):"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueLabelStyle}"
                                       Text="{Binding LastOutput.MaxSplDb, StringFormat={}{0:F1}}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Min STI:"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueLabelStyle}"
                                       Text="{Binding LastOutput.MinSti, StringFormat={}{0:F2}}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Max STI:"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueLabelStyle}"
                                       Text="{Binding LastOutput.MaxSti, StringFormat={}{0:F2}}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Compute Time:"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueLabelStyle}"
                                       Text="{Binding LastOutput.ComputeTimeSeconds, StringFormat={}{0:F2}s}"/>
                        </Grid>

                        <Border Style="{StaticResource Separator}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Legend" Margin="0,4,0,8"/>
                        <ItemsControl ItemsSource="{Binding LegendItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Border Width="28" Height="16" CornerRadius="2" Margin="0,0,8,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding ColorValue}"/>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource ValueLabelStyle}"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

                <!-- Status Strip -->
                <Border Grid.Row="2"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="10,0">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource IconForegroundBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Resize grips -->
        <Border Width="4" HorizontalAlignment="Left" Margin="6,20,0,14" Background="Transparent"
                Cursor="SizeWE" MouseDown="ResizeLeft_MouseDown"/>
        <Border Width="4" HorizontalAlignment="Right" Margin="0,20,6,14" Background="Transparent"
                Cursor="SizeWE" MouseDown="ResizeRight_MouseDown"/>
        <Border Height="4" VerticalAlignment="Bottom" Margin="14,0,14,6" Background="Transparent"
                Cursor="SizeNS" MouseDown="ResizeBottom_MouseDown"/>
        <Border Width="14" Height="14" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="6,0,0,6" Background="Transparent" Cursor="SizeNESW"
                MouseDown="ResizeBottomLeft_MouseDown"/>
        <Border Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,6,6" Background="Transparent" Cursor="SizeNWSE"
                MouseDown="ResizeBottomRight_MouseDown"/>
    </Grid>
</Window>
