<UserControl x:Class="SoundCalcs.UI.AcousticViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF">
    <Grid Background="#FF1F1F1F">

        <!-- GPU-composited Skia surface: heatmap + walls + speakers -->
        <skia:SKElement x:Name="SkCanvas"
                        PaintSurface="OnPaintSurface"
                        MouseWheel="Canvas_MouseWheel"
                        MouseDown="Canvas_MouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseUp="Canvas_MouseUp"
                        Cursor="Hand"
                        Focusable="True"/>

        <!-- Top-right: viewer controls -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                    Orientation="Horizontal" Margin="0,6,8,0">

            <Button x:Name="ClearPinsBtn"
                    Content="Clear"
                    Width="38" Height="22"
                    Margin="0,0,4,0"
                    Visibility="Collapsed"
                    Click="ClearPinsBtn_Click"
                    FontSize="10"
                    Background="#33FFFFFF" Foreground="#CCCCCC"
                    BorderBrush="#44FFFFFF" BorderThickness="1"
                    Cursor="Arrow"/>

            <Button x:Name="ProbeBtn"
                    Content="Probe"
                    Width="44" Height="22"
                    Margin="0,0,4,0"
                    Click="ProbeBtn_Click"
                    FontSize="10"
                    Background="#33FFFFFF" Foreground="#CCCCCC"
                    BorderBrush="#44FFFFFF" BorderThickness="1"
                    Cursor="Arrow"/>

            <Button x:Name="FitBtn"
                    Content="Fit"
                    Width="36" Height="22"
                    Click="FitBtn_Click"
                    FontSize="10"
                    Background="#33FFFFFF" Foreground="#CCCCCC"
                    BorderBrush="#44FFFFFF" BorderThickness="1"
                    Cursor="Arrow"/>

        </StackPanel>

    </Grid>
</UserControl>
